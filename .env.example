# ── Témoigne de moi v2 — Variables d'environnement ───────────────────────────
# Copiez ce fichier en .env et renseignez vos valeurs.
# Sur Render : ajoutez ces variables dans "Environment" (jamais commiter .env).

# ── Resend (OBLIGATOIRE) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── Email ─────────────────────────────────────────────────────────────────────
DEST_EMAIL=votre@email.fr
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Témoigne de moi
CONTACT_EMAIL=rgpd@votre-eglise.fr

# ── Application ───────────────────────────────────────────────────────────────
APP_TITLE=Témoigne de moi
APP_SUBTITLE=Votre voix, votre histoire
FOOTER_TEXT=Envoyé via Témoigne de moi
BADGE_TEXT=Votre voix compte
HERO_TITLE=Témoigne|de moi

# ── TinyMCE ───────────────────────────────────────────────────────────────────
TINYMCE_KEY=votre-cle-tinymce

# ── Sécurité ──────────────────────────────────────────────────────────────────
# OBLIGATOIRE en production — chaîne aléatoire d'au moins 32 caractères
COOKIE_SECRET=changez-moi-32-caracteres-minimum
# Mot de passe de la page /admin
ADMIN_PASSWORD=changez-moi

# ── Audio / Vidéo / Écrit — seuils pièce jointe (MB) ─────────────────────────
AUDIO_PREFIX=vocal
AUDIO_SIZE_MB=10
VIDEO_SIZE_MB=25
ECRIT_SIZE_MB=5

# ── Stockage distant (optionnel) ──────────────────────────────────────────────
# Type : none | gdrive | ftp | webhook
STORAGE_TYPE=none

# Google Drive
# GDRIVE_FOLDER_ID=1AbCdEfGhIjKlMn
# GDRIVE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# FTP
# FTP_HOST=ftp.monserveur.com
# FTP_PORT=21
# FTP_USER=user
# FTP_PASSWORD=motdepasse
# FTP_PATH=/public_html/uploads
# FTP_PUBLIC_URL=https://monsite.com/uploads
# FTP_SECURE=true

# Webhook
# WEBHOOK_URL=https://mon-serveur.com/upload
# WEBHOOK_SECRET=mon-secret

# ── Port (Render le définit automatiquement) ──────────────────────────────────
PORT=3000
